{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sfskills/agents/integration-catalog-builder/inputs.schema.json",
  "title": "integration-catalog-builder inputs",
  "description": "Typed Gate-A input contract for the integration-catalog-builder.",
  "type": "object",
  "required": ["catalog_name", "org_alias", "feature_summary", "api_version"],
  "properties": {
    "catalog_name": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"},
    "org_alias": {"type": "string", "minLength": 1},
    "feature_summary": {"type": "string", "minLength": 1, "description": "≥10 words"},
    "named_credentials": {
      "type": "array",
      "items": {"type": "string"},
      "description": "API names of Named Credentials referenced in the catalog (used for Gate C live verification)."
    },
    "api_version": {"type": "string", "pattern": "^\\d{2}\\.0$"},
    "target_org_alias": {"type": "string"},
    "repo_path": {"type": "string", "default": "./force-app"}
  }
}
