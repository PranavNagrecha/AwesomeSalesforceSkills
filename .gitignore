.DS_Store
__pycache__/
*.pyc
*.pyo

# lexical.sqlite grows past GitHub's 50 MB limit — regenerate with: python3 scripts/skill_sync.py --all
vector_index/lexical.sqlite

# chunks.jsonl crosses GitHub's 50 MB warning threshold (~98 MB at 690 skills
# and growing). Regenerate locally or in CI via `python3 scripts/build_index.py`
# before any validation or drift check. registry/ + vector_index/manifest.json
# stay committed — they encode the content hash that detects rebuild drift,
# so CI can verify reproducibility without the raw bytes.
vector_index/chunks.jsonl

# Export tree is a generated artifact (~130 MB for claude+mcp+cursor+windsurf+
# aider+augment at 684 skills). Consumers regenerate via:
#   python3 scripts/export_skills.py --all
# The committed registry/export_manifest.json records per-target content hashes
# so CI parity checks don't need the bytes — just the hashes.
exports/

# Claude Code worktrees (temporary agent working copies)
.claude/worktrees/

# Codex ↔ Claude Code handoff zone: raw skill file drops (=== FILE: ... ===
# format) that Claude Code picks up, writes into the tree, syncs, validates,
# and commits. Processed files go under _codex_drops/processed/. The zone
# itself is tracked (README + prompt) but individual drops are not.
_codex_drops/*.txt
_codex_drops/*.out
_codex_drops/processed/

# Per-run reports generated by scripts/run_builder.py — each gated run writes
# REQUIREMENTS.md, state.json, envelope.json, report.md under
# docs/reports/<agent>/<run_id>/. Transient CI/debug artifacts; regenerate via:
#   python3 scripts/run_builder.py --agent <agent> --fixture <...> --emitted-dir <...>
docs/reports/

# scripts/execute_agent_fixture.py debug artifact — the assembled prompt sent
# to the model. Reproducible from the fixture + agent source, ~37 KB per run,
# noisy to diff. The raw.md (model response), envelope.json (extracted
# envelope), and grade.txt (grader verdict) alongside it ARE committed as the
# persistent record of each agent execution.
docs/validation/agent_executions_*/*.prompt.txt

# Local Claude Code session state (user-specific, not part of repo)
.claude/
