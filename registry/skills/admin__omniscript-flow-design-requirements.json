  "dependencies": [],
  "description": "Use this skill to gather, document, and validate OmniScript flow design requirements before development begins \u2014 covering screen layout requirements, branching logic, data source requirements, and user journey mapping. Trigger keywords: OmniScript requirements, OmniScript BA, OmniScript screen design, OmniScript user journey, OmniScript branching requirements. NOT for OmniScript development implementation, DataRaptor mapping, Integration Procedure design, or standard Screen Flow requirements.",
  "file_location": "skills/admin/omniscript-flow-design-requirements",
  "id": "admin/omniscript-flow-design-requirements",
  "inputs": [
    "Business process description and user journey narrative",
    "List of data objects and fields the OmniScript must read or write",
    "Branching rules and conditional logic scenarios",
    "Persona or user role context (internal agent, community user, Experience Cloud)"
  ],
  "name": "omniscript-flow-design-requirements",
  "official_sources": [
    "OmniScript Best Practices \u2014 https://help.salesforce.com/s/articleView?id=sf.os_omniscript_best_practices.htm",
